    {
        "id": "ex07-features",
        "type": "function",
        "z": "ex07-tab",
        "name": "build feature vector",
        "func": "// [temperature, vibration, pressure, rpm]\nconst features = [\n    +(68 + (Math.random() - 0.5) * 4).toFixed(2),\n    +(2.2 + (Math.random() - 0.5) * 0.8).toFixed(3),\n    +(5.1 + (Math.random() - 0.5) * 0.3).toFixed(3),\n    +(1480 + (Math.random() - 0.5) * 20).toFixed(0)\n];\nmsg.payload = features;\nmsg.topic = 'machine-a/features';\nreturn msg;",
        "outputs": 1,
        "noerr": 0,
