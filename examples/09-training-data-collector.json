        "bufferSize": 1000,
        "windowSize": 100,
        "windowOverlap": 50,
        "flushOnDeploy": true,
        "exportFormat": "csv",
        "compressionEnabled": true,
        "compressionThreshold": 10000,
        "splitTrain": 80,
        "splitVal": 10,
        "splitTest": 10,
        "shuffleOnExport": true,
        "includeMetadata": true,
        "s3Enabled": false,
        "s3Bucket": "",
